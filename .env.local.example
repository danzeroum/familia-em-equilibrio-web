# ─────────────────────────────────────────────────────────────────────────────
# Para desenvolvimento local (next dev) SEM Docker
# Copie este arquivo para .env.local e preencha com os seus valores
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Cloud ou self-hosted local) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Em dev local sem Docker, SUPABASE_URL pode ser igual ao NEXT_PUBLIC
# Em Docker, mude para: http://kong:8000
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_API_BASE=https://your-llm-endpoint.example.com
LLM_API_KEY=your_llm_api_key_here
LLM_DEFAULT_MODEL=qwen2.5:7b
