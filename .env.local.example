# Para desenvolvimento local (next dev) sem Docker — aponta para Supabase Cloud ou local
# Copie este arquivo para .env.local e preencha com os seus valores

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# LLM
LLM_API_BASE=https://your-llm-endpoint.example.com
LLM_API_KEY=your_llm_api_key_here
LLM_DEFAULT_MODEL=qwen2.5:7b
