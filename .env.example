# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com os seus valores
# Para gerar JWT_SECRET:       openssl rand -base64 32
# Para gerar ANON_KEY e SERVICE_ROLE_KEY: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# ─────────────────────────────────────────────────────────────────────────────

# ── App (browser — baked no build Docker) ────────────────────────────────────
# Aponta para o Kong (gateway do Supabase self-hosted) acessível do browser
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── App (server-side — API Routes dentro do container Next.js) ───────────────
# OBRIGATÓRIO no Docker: usa o nome de rede interno "kong" em vez de localhost
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── LLM (Ollama ou outro provider) ───────────────────────────────────────────
LLM_API_BASE=https://your-llm-endpoint.example.com
LLM_API_KEY=your_llm_api_key_here
LLM_DEFAULT_MODEL=qwen2.5:7b

# ── Supabase Self-Hosted ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_postgres_password
JWT_SECRET=your_jwt_secret_min_32_chars
ANON_KEY=your_anon_key_here
SERVICE_ROLE_KEY=your_service_role_key_here
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
